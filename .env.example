# ── Telegram ───────────────────────────────────────────────────────────────────
# From @BotFather → /mybots → select bot → API Token
BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram ID (message @userinfobot to get it)
OWNER_CHAT_ID=your_telegram_user_id

# Bot username without @ (e.g. cashbridgebot)
BOT_USERNAME=cashbridgebot

# Your private vault channel ID — starts with -100
# Get it: add @userinfobot to the channel, it shows the ID
VAULT_CHANNEL_ID=-1001234567890

# ── Paystack ───────────────────────────────────────────────────────────────────
# Dashboard → Settings → API Keys & Webhooks → Secret key
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# Dashboard → Settings → Webhooks → your webhook secret
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret_here

# ── Business settings ──────────────────────────────────────────────────────────
SUBSCRIPTION_PRICE_USD=10
COMMISSION_RATE=0.30

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── Optional ───────────────────────────────────────────────────────────────────
# Set to "true" to enable debug log output
DEBUG=false
